{
  "name": "@db-ux-inner-source/ri-extension-components",
  "version": "1.1.1",
  "description": "RI Components (local stripped bundle for GitHub Pages deployment)",
  "type": "module",
  "main": "dist/bundle/ri-components.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    "./types/*": "./dist/types/*",
    "./styles/*": "./dist/styles/*",
    "./headless/*": "./dist/headless/*",
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/bundle/ri-components.js"
    }
  },
  "files": [
    "/dist",
    "LICENSE"
  ],
  "dependencies": {
    "lit": "3.3.1",
    "lit-html": "3.3.1"
  },
  "peerDependencies": {
    "@db-ux/core-components": "^4",
    "@db-ux/core-foundations": "^4"
  },
  "license": "LicenseRef-DBISL"
}
